{
  "entities": {
    "users": {
      "title": "Users",
      "description": "User profiles including students, teachers and admins",
      "type": "object",
      "properties": {
        "nom": { "type": "string" },
        "prenom": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "enseignant", "élève", "parent"] },
        "classe": { "type": "string" },
        "matricule": { "type": "string" },
        "photo": { "type": "string" },
        "cover_photo": { "type": "string" },
        "biographie": { "type": "string" },
        "matieres": { "type": "array", "items": { "type": "string" } },
        "gender": { "type": "string" },
        "age": { "type": "number" },
        "address": { "type": "string" },
        "contact": { "type": "string" },
        "date_creation": { "type": "string", "format": "date-time" },
        "face_id": { "type": "string" },
        "fingerprint_id": { "type": "string" },
        "credential_id": { "type": "string" },
        "maison": { "type": "string" }
      }
    },
    "attendance": {
      "title": "Daily Attendance Summary",
      "description": "Summary of user attendance per day",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "heure_arrivee": { "type": "string" },
        "heure_depart": { "type": "string" },
        "statut": { "type": "string", "enum": ["Présent", "Retard", "Absent"] },
        "current_state": { "type": "string", "enum": ["présent", "sorti"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "attendance_logs": {
      "title": "Detailed Attendance Logs",
      "description": "Individual scan entries for entry and exit",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "user_name": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "time": { "type": "string" },
        "type": { "type": "string", "enum": ["entrée", "sortie"] },
        "isLate": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "clubs": {
      "title": "Clubs",
      "description": "School clubs and extracurricular activities",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "leaderId": { "type": "string" },
        "leaderName": { "type": "string" },
        "category": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "grades": {
      "title": "Grades",
      "description": "Student evaluation scores",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "subject": { "type": "string" },
        "score": { "type": "number" },
        "maxScore": { "type": "number" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["interrogation", "evaluation"] },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "sanctions": {
      "title": "Discipline Sanctions",
      "description": "Disciplinary records for students",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "studentName": { "type": "string" },
        "type": { "type": "string", "enum": ["warning", "detention", "exclusion"] },
        "reason": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "completed", "cancelled"] },
        "recordedBy": { "type": "string" },
        "date": { "type": "string", "format": "date-time" }
      }
    },
    "homework": {
      "title": "Homework",
      "description": "Assignments and lesson contents",
      "type": "object",
      "properties": {
        "classId": { "type": "string" },
        "subject": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "teacherId": { "type": "string" },
        "teacherName": { "type": "string" },
        "completedBy": { "type": "array", "items": { "type": "string" } },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "preparations": {
      "title": "Courses and Preparations",
      "description": "Educational content and AI-generated lesson plans",
      "type": "object",
      "properties": {
        "topic": { "type": "string" },
        "subject": { "type": "string" },
        "grade": { "type": "string" },
        "content": { "type": "string" },
        "type": { "type": "string", "enum": ["course", "exercise", "quiz"] },
        "authorId": { "type": "string" },
        "authorName": { "type": "string" },
        "fileUrl": { "type": "string" },
        "fileName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "notifications": {
      "title": "Notifications",
      "description": "System and user notifications",
      "type": "object",
      "properties": {
        "user_id": { "type": "string" },
        "type": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["sent", "read"] },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    },
    "user_sessions": {
      "title": "User Sessions",
      "description": "Active and past user login sessions with device and location info",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "device": { "type": "string" },
        "os": { "type": "string" },
        "browser": { "type": "string" },
        "location": { "type": "string" },
        "ip": { "type": "string" },
        "lastActive": { "type": "string", "format": "date-time" },
        "userAgent": { "type": "string" },
        "isMobile": { "type": "boolean" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      }
    }
  },
  "firestore": {
    "/users/{userId}": { "schema": "users", "description": "User documents" },
    "/attendance/{attId}": { "schema": "attendance", "description": "Daily summaries" },
    "/attendance_logs/{logId}": { "schema": "attendance_logs", "description": "Scans logs" },
    "/clubs/{clubId}": { "schema": "clubs", "description": "Club documents" },
    "/grades/{gradeId}": { "schema": "grades", "description": "Grade entries" },
    "/sanctions/{sanctionId}": { "schema": "sanctions", "description": "Discipline entries" },
    "/homework/{homeworkId}": { "schema": "homework", "description": "Homework assignments" },
    "/preparations/{prepId}": { "schema": "preparations", "description": "Lesson plans and courses" },
    "/notifications/{notifId}": { "schema": "notifications", "description": "User notifications" },
    "/user_sessions/{sessionId}": { "schema": "user_sessions", "description": "Real-time user sessions" }
  }
}
